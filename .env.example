# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://esb:changeme@localhost:5432/esb_portal

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
SESSION_TTL_SECONDS=86400          # 24h standard sessions
SESSION_TTL_STEP_UP_SECONDS=3600   # 1h step-up (finance / validation-flag)

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# ── Dropbox Sign ──────────────────────────────────────────────────────────────
DROPBOX_SIGN_API_KEY=...
DROPBOX_SIGN_WEBHOOK_SECRET=...

# ── AI providers (independence rule: two distinct vendors) ────────────────────
ANTHROPIC_API_KEY=...              # primary — Stage-2 content review
OPENAI_API_KEY=...                 # secondary — independent red-teamer / grader

# ── Content pipeline ──────────────────────────────────────────────────────────
PIPELINE_STAGE2_TIMEOUT_SECONDS=30
PIPELINE_STAGE2_TOKEN_CEILING=2000
PIPELINE_CIRCUIT_BREAKER_THRESHOLD=5   # failures before circuit opens

# ── AI-ops cost ceilings (USD/day per subsystem) ─────────────────────────────
AI_COST_CEILING_CONTENT=50
AI_COST_CEILING_TRANSCRIPTION=20
AI_COST_CEILING_GRADER=30

# ── Email (Postmark inbound BCC routing) ─────────────────────────────────────
POSTMARK_SERVER_TOKEN=...
BCC_INBOUND_ADDRESS=log@gotbindex.com

# ── Backup / DR ───────────────────────────────────────────────────────────────
BACKUP_ENCRYPTION_KEY=...          # GPG key fingerprint
BACKUP_DESTINATION=s3://esb-portal-backups
BACKUP_RPO_MINUTES=60
BACKUP_RTO_MINUTES=120

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development            # development | staging | production
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ALLOWED_EMBED_ORIGINS=["https://greatontheirbehalf.com"]

# ── i18n ──────────────────────────────────────────────────────────────────────
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=["en","es"]
